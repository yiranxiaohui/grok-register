TZ=Asia/Shanghai
GROK_REGISTER_LITE_PORT=8788

TURNSTILE_BROWSER_AUTO_FETCH=1
TURNSTILE_BROWSER_TYPE=camoufox
# TURNSTILE_BROWSER_FORCE_FETCH=1
