# 复制为 .env 并按需修改（.env 已被 .gitignore 忽略，不会入库）

# 时区
TZ=Asia/Shanghai

# 宿主机映射端口（访问 http://IP:端口/admin）
GROK_REGISTER_LITE_PORT=8788

# 数据目录（挂载到容器 /data，删容器不丢数据）
GROK_REGISTER_HOST_DATA_DIR=./data

# 管理路径（可改成 /panel 等隐藏入口）
GROK_REGISTER_ADMIN_BASE_PATH=/admin

# 首次启动管理员密码（务必改成强密码）
GROK_REGISTER_ADMIN_BOOTSTRAP_PASSWORD=change-me-to-a-strong-password

# 强制用上面密码重置管理员（改密后务必改回 0）
GROK_REGISTER_ADMIN_FORCE_RESET=0

# 过盾并发线程数（内存小改 1）
TURNSTILE_THREAD=2
